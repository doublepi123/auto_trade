{
  "$schema": "https://opencode.ai/config.json",
  "lsp": {
    "biome": {
      "disabled": true
    },
    "basedpyright": {
      "command": ["backend/.venv/bin/basedpyright-langserver", "--stdio"],
      "extensions": [".py", ".pyi"]
    },
    "typescript": {
      "command": ["npx", "--prefix", "frontend", "typescript-language-server", "--stdio"],
      "extensions": [".ts", ".tsx", ".js", ".jsx", ".mjs", ".cjs", ".mts", ".cts"]
    }
  }
}
