AUTO_TRADE_ENV=dev
# 本机开发：相对路径，cwd = repo 根或 backend/ 均可
# Docker：compose 中覆盖为 sqlite:////app/data/auto_trade.db
AUTO_TRADE_DATABASE_URL=sqlite:///./data/auto_trade.db
LONGPORT_APP_KEY=
LONGPORT_APP_SECRET=
LONGPORT_ACCESS_TOKEN=
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=
AUTO_TRADE_SCT_KEY=
AUTO_TRADE_FRONTEND_PORT=8080
# AUTO_TRADE_FRONTEND_BIND 控制前端容器对外暴露的接口：内网/演示环境用 0.0.0.0，
# 仅本机访问用 127.0.0.1。详见 docker-compose.yaml。
# AUTO_TRADE_FRONTEND_BIND=0.0.0.0
AUTO_TRADE_API_KEY=change-me-please  # 必填：docker compose 启动时会强制校验（${AUTO_TRADE_API_KEY:?}）
CREDENTIAL_MASTER_KEY=
AUTO_TRADE_LLM_PROVIDER=deepseek           # deepseek | minimax
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-pro          # 默认 deepseek-v4-pro
# DEEPSEEK_REASONING_EFFORT=max           # thinking 力度：high | max（默认 max）
# DEEPSEEK_THINKING_TYPE=enabled          # enabled | disabled
# DEEPSEEK_MAX_TOKENS=262144              # 单次响应最大 token
MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1 # Token Plan base URL
# MINIMAX_API_URL=                         # 兼容旧配置：完整 /chat/completions endpoint
# MINIMAX_MODEL=MiniMax-M3                # 默认 MiniMax-M3
# MINIMAX_THINKING_TYPE=adaptive          # adaptive | disabled
# MINIMAX_MAX_COMPLETION_TOKENS=8192      # 单次响应最大 completion token

# --- LLM 顾问阈值 (P4+ / P7') ---
# AUTO_TRADE_LLM_INTERVAL_MINUTES=2       # 两次 LLM 分析之间的最短间隔（分钟，默认 2）
# AUTO_TRADE_LLM_MIN_CONFIDENCE=0.7       # 低于此置信度不应用 LLM 区间建议
# AUTO_TRADE_LLM_MAX_STRIPE_WIDTH_PCT=8.0 # 区间宽度过大则拒绝（%）
# AUTO_TRADE_LLM_VOLATILITY_THRESHOLD_PCT=1.0 # 触发 LLM 重分析的瞬时波动阈值（%）
# AUTO_TRADE_LLM_MAX_SYMBOLS_PER_CYCLE=1  # 每个 cron tick 处理的最大 symbol 数
# AUTO_TRADE_LLM_MAX_ANALYSES_PER_HOUR=30 # 每小时全局 LLM 分析预算
# AUTO_TRADE_LLM_EXPERIMENT_NAME=         # 可选：把 LLM 决策关联到实验

# --- 风控 / 实盘费率 (P4) ---
# AUTO_TRADE_FEE_RATE_US=0.0001            # 美股双边费率估算（默认 1 bps）
# AUTO_TRADE_FEE_RATE_HK=0.001             # 港股双边费率估算（默认 10 bps）
# AUTO_TRADE_MIN_REPRICING_PCT=0.1         # LLM cancel-replace 最小改价阈值（%）
# AUTO_TRADE_LLM_ACTION_COOLDOWN_SECONDS=300 # LLM 同方向发单冷却（秒）

AUTO_TRADE_MIN_EXIT_PROFIT_PCT=0.2

# --- 交易时段守卫 (P5+) ---
# AUTO_TRADE_TRADING_SESSION_MODE=ANY      # ANY = 不限制；RTH_ONLY = 仅常规交易时段
# 注意：仅周末 + 常规 RTH 时段判断，**不含节假日历**。

# --- 引擎冷却 (P6) ---
# AUTO_TRADE_ENGINE_COOLDOWN_SECONDS=60    # 同一 trigger 触发后的冷却秒数

# --- 重试 / 审计 ---
# AUTO_TRADE_BROKER_RETRY_MAX=3            # 订单类券商调用最大重试次数
# AUTO_TRADE_BROKER_QUOTE_RETRY_MAX=1      # 行情类券商调用最大重试次数
# AUTO_TRADE_BROKER_RETRY_BASE_MS=1000     # 指数退避基数（毫秒）
# AUTO_TRADE_AUDIT_REQUEST_SUMMARY_LIMIT=2048

# --- CORS ---
# AUTO_TRADE_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
