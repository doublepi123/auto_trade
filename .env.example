AUTO_TRADE_ENV=prod
# 本机开发：相对路径，cwd = repo 根或 backend/ 均可
# Docker：compose 中覆盖为 sqlite:////app/data/auto_trade.db
AUTO_TRADE_DATABASE_URL=sqlite:///./data/auto_trade.db
LONGPORT_APP_KEY=
LONGPORT_APP_SECRET=
LONGPORT_ACCESS_TOKEN=
LONGBRIDGE_APP_KEY=
LONGBRIDGE_APP_SECRET=
LONGBRIDGE_ACCESS_TOKEN=
AUTO_TRADE_SCT_KEY=
AUTO_TRADE_FRONTEND_PORT=8080
# AUTO_TRADE_FRONTEND_BIND 控制前端容器对外暴露的接口：内网/演示环境用 0.0.0.0，
# 仅本机访问用 127.0.0.1。详见 docker-compose.yaml。
# AUTO_TRADE_FRONTEND_BIND=0.0.0.0
AUTO_TRADE_API_KEY=change-me-please  # 必填：docker compose 启动时会强制校验（${AUTO_TRADE_API_KEY:?}）
CREDENTIAL_MASTER_KEY=
AUTO_TRADE_LLM_PROVIDER=deepseek           # deepseek | minimax
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-pro          # 默认 deepseek-v4-pro
# DEEPSEEK_REASONING_EFFORT=max           # thinking 力度：high | max（默认 max）
# DEEPSEEK_THINKING_TYPE=enabled          # enabled | disabled
# DEEPSEEK_MAX_TOKENS=262144              # 单次响应最大 token
MINIMAX_API_KEY=
# MINIMAX_BASE_URL=https://api.minimaxi.com/v1 # Token Plan base URL
# MINIMAX_API_URL=                         # 兼容旧配置：完整 /chat/completions endpoint
# MINIMAX_MODEL=MiniMax-M3                # 默认 MiniMax-M3
# MINIMAX_THINKING_TYPE=adaptive          # adaptive | disabled
# MINIMAX_MAX_COMPLETION_TOKENS=8192      # 单次响应最大 completion token

# --- LLM 顾问阈值 (P4+ / P7') ---
# AUTO_TRADE_LLM_INTERVAL_MINUTES=2       # 两次 LLM 分析之间的最短间隔（分钟，默认 2）
# AUTO_TRADE_LLM_MIN_CONFIDENCE=0.7       # 低于此置信度不应用 LLM 区间建议
# AUTO_TRADE_LLM_MAX_STRIPE_WIDTH_PCT=8.0 # 区间宽度过大则拒绝（%）
# AUTO_TRADE_LLM_MAX_INTERVAL_BOUND_DEVIATION_PCT=5.0 # 区间上下界相对现价最大偏离（%）
# AUTO_TRADE_LLM_VOLATILITY_THRESHOLD_PCT=1.0 # 触发 LLM 重分析的瞬时波动阈值（%）
# AUTO_TRADE_LLM_MAX_SYMBOLS_PER_CYCLE=1  # 每个 cron tick 处理的最大 symbol 数
# AUTO_TRADE_LLM_MAX_ANALYSES_PER_HOUR=30 # 每小时全局 LLM 分析预算
# AUTO_TRADE_LLM_EXPERIMENT_NAME=         # 可选：把 LLM 决策关联到实验
# AUTO_TRADE_LLM_INTERACTION_RETENTION_DAYS=90 # 失败、动作、已应用/关联订单记录的保留天数；0 表示不按此窗口删除
# AUTO_TRADE_LLM_NO_ACTION_RETENTION_DAYS=14  # 成功且未应用、无订单关联的 NONE 记录保留天数；0 表示关闭短窗口
# AUTO_TRADE_LLM_CONTEXT_SNAPSHOT_MAX_BYTES=16384 # 新快照上限；超限时均匀采样行情并保留关键审计上下文
# AUTO_TRADE_LLM_STORAGE_MAINTENANCE_INTERVAL_MINUTES=360 # 在线分批清理周期；不会执行 VACUUM
# AUTO_TRADE_LLM_STORAGE_MAINTENANCE_BATCH_SIZE=250 # 每事务删除上限及每轮旧快照整理上限
# P0 固定为 LLM 影子模式；以下兼容字段必须保持 true，改为 false 也不会开启实盘下单。
# AUTO_TRADE_LLM_SHADOW_MODE=true
# AUTO_TRADE_LLM_MAX_ORDER_PRICE_DEVIATION_PCT=1.0 # 保留的 LLM 订单守卫；P0 不下单

# --- 风控 / 实盘费率 (P4) ---
# AUTO_TRADE_FEE_RATE_US=0.0001            # 美股双边费率估算（默认 1 bps）
# AUTO_TRADE_FEE_RATE_HK=0.001             # 港股双边费率估算（默认 10 bps）
# AUTO_TRADE_MIN_REPRICING_PCT=0.1         # 保留参数；P0 不执行 LLM cancel-replace
# AUTO_TRADE_LLM_ACTION_COOLDOWN_SECONDS=300 # 保留参数；P0 不执行 LLM 实盘发单

# --- P0 默认实盘硬边界 ---
# P0 固定禁用做空开仓、已有持仓加仓和 LLM 实盘下单，不提供环境变量绕过。
# AUTO_TRADE_HARD_ALLOW_POSITION_ADDONS=false # 兼容字段；改为 true 也不会启用加仓
# AUTO_TRADE_HARD_MAX_POSITION_QUANTITY=100
# AUTO_TRADE_HARD_MAX_POSITION_NOTIONAL=5000 # 标的报价币种
# AUTO_TRADE_HARD_MAX_RISK_PER_TRADE=250     # 标的报价币种
# 仅模拟账户：true 时按券商最大保证金可买数量的 100% 开仓，并绕过上述三项定仓上限。
# AUTO_TRADE_FULL_BUYING_POWER_USAGE_ENABLED=false
# 动态候选池只改变只读 watchlist/shadow，不会自动切换主交易标的。
# AUTO_TRADE_UNIVERSE_SELECTION_ENABLED=false
# AUTO_TRADE_UNIVERSE_SELECTION_APPLY_TO_WATCHLIST=false
# AUTO_TRADE_UNIVERSE_SELECTION_ENABLE_SHADOW=false  # 仅在 APPLY_TO_WATCHLIST=true 时可启用
# AUTO_TRADE_UNIVERSE_SELECTION_INTERVAL_MINUTES=60
# AUTO_TRADE_UNIVERSE_SELECTION_MAX_SYMBOLS=8
# AUTO_TRADE_UNIVERSE_SELECTION_MAX_PER_SECTOR=2
# AUTO_TRADE_UNIVERSE_SELECTION_MIN_EVALUABLE_RATIO=0.60
# AUTO_TRADE_UNIVERSE_SELECTION_MIN_RESIDENCY_DAYS=2
# AUTO_TRADE_UNIVERSE_SELECTION_MIN_PRICE=10
# AUTO_TRADE_UNIVERSE_SELECTION_MIN_AVG_DOLLAR_VOLUME=500000000
# AUTO_TRADE_UNIVERSE_SELECTION_MAX_SPREAD_BPS=15
# AUTO_TRADE_UNIVERSE_SELECTION_MIN_REALIZED_VOL=0.15
# AUTO_TRADE_UNIVERSE_SELECTION_MAX_REALIZED_VOL=1.20
# AUTO_TRADE_UNIVERSE_SELECTION_MIN_ATR_PCT=0.75
# AUTO_TRADE_UNIVERSE_SELECTION_MAX_ATR_PCT=8
# live regime gate 使用当前主标的最新 Strategy v2 shadow 证据；减仓永远绕过。
# AUTO_TRADE_LIVE_REGIME_GATE_ENABLED=false
# AUTO_TRADE_LIVE_REGIME_MAX_DATA_AGE_SECONDS=600
# AUTO_TRADE_LIVE_MAX_ENTRIES_PER_SYMBOL_PER_DAY=2
# AUTO_TRADE_HARD_STOP_LOSS_PCT=1.0
# AUTO_TRADE_HARD_MAX_HOLDING_MINUTES=60
# AUTO_TRADE_HARD_ENTRY_CUTOFF_MINUTES_BEFORE_CLOSE=45
# AUTO_TRADE_HARD_FLATTEN_MINUTES_BEFORE_CLOSE=15

AUTO_TRADE_MIN_EXIT_PROFIT_PCT=0.2

# --- 交易时段守卫 (P5+) ---
# AUTO_TRADE_TRADING_SESSION_MODE=ANY      # ANY = 不限制；RTH_ONLY = 仅常规交易时段
# 包含 2024–2027 年 NYSE / HKEX 休市日与提前收盘时间；超出覆盖年份需更新日历。

# --- 引擎冷却 (P6) ---
# AUTO_TRADE_ENGINE_COOLDOWN_SECONDS=60    # 同一 trigger 触发后的冷却秒数

# --- 重试 / 审计 ---
# AUTO_TRADE_BROKER_RETRY_MAX=3            # 订单类券商调用最大重试次数
# AUTO_TRADE_BROKER_QUOTE_RETRY_MAX=1      # 行情类券商调用最大重试次数
# AUTO_TRADE_BROKER_RETRY_BASE_MS=1000     # 指数退避基数（毫秒）
# AUTO_TRADE_BROKER_POSITION_SNAPSHOT_ISOLATION_ENABLED=true # 独立进程读取持仓，避免 SDK 卡死阻塞主服务
# AUTO_TRADE_BROKER_POSITION_SNAPSHOT_TIMEOUT_SECONDS=8      # 持仓探针硬超时（1–60 秒）
# AUTO_TRADE_AUDIT_REQUEST_SUMMARY_LIMIT=2048
# AUTO_TRADE_AUDIT_TRUSTED_PROXY_CIDRS=172.16.0.0/12 # Docker nginx network only

# --- CORS ---
# AUTO_TRADE_CORS_ORIGINS=http://localhost:3000,http://localhost:8080
